{
    "version": 2,
    "name": "demeni-sites",
    "public": true,
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "sites.rafaeldemeni.com"
                }
            ],
            "destination": "/sites.html"
        },
        {
            "source": "/sites",
            "destination": "/sites.html"
        },
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/app",
            "destination": "/app.html"
        },
        {
            "source": "/core",
            "destination": "/core.html"
        },
        {
            "source": "/editor",
            "destination": "/editor.html"
        },
        {
            "source": "/about",
            "destination": "/about.html"
        },
        {
            "source": "/pricing",
            "destination": "/pricing.html"
        },
        {
            "source": "/ajuda",
            "destination": "/ajuda.html"
        },
        {
            "source": "/aulas",
            "destination": "/aulas.html"
        },
        {
            "source": "/s/:slug",
            "destination": "/api/subdomain?s=:slug"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        },
        {
            "source": "/core-sw.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/core.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, must-revalidate"
                }
            ]
        },
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, must-revalidate"
                }
            ]
        }
    ]
}